#!/usr/bin/env bash
# cybertrans-finder-setup — installs / removes Finder Quick Actions for CyberTranscoding
set -euo pipefail

SERVICES_DIR="$HOME/Library/Services"
CYBERTRANS="/opt/homebrew/bin/cybertrans"

BOLD=$'\033[1m'; RESET=$'\033[0m'
PINK=$'\033[38;5;198m'; BLUE=$'\033[38;5;27m'
GREEN=$'\033[38;5;46m'; RED=$'\033[38;5;196m'
GREY=$'\033[38;5;240m'

# Preset names and their corresponding flags (parallel arrays)
NAMES=(
  "CyberTrans · H.264 FHD · audio"
  "CyberTrans · H.264 FHD · silent"
  "CyberTrans · H.265 FHD · audio"
  "CyberTrans · H.265 FHD · silent"
)
FLAGS=(
  "--codec h264 --res fhd --audio keep"
  "--codec h264 --res fhd --audio strip"
  "--codec h265 --res fhd --audio keep"
  "--codec h265 --res fhd --audio strip"
)

uninstall() {
  local removed=0
  for name in "${NAMES[@]}"; do
    local bundle="$SERVICES_DIR/${name}.workflow"
    if [[ -d "$bundle" ]]; then
      rm -rf "$bundle"
      echo "  ${RED}✘${RESET} removed: ${GREY}${name}.workflow${RESET}"
      ((removed++)) || true
    fi
  done
  if (( removed == 0 )); then
    echo "  ${GREY}nothing to remove.${RESET}"
  else
    echo ""
    echo "  ${GREEN}✓${RESET} ${removed} Quick Action(s) removed."
  fi
}

make_workflow() {
  local name="$1"
  local flags="$2"
  local bundle="$SERVICES_DIR/${name}.workflow"
  local contents="$bundle/Contents"

  mkdir -p "$contents"

  # Build the shell command that runs inside the workflow.
  # Automator has a minimal PATH and no TTY, so we can't call cybertrans directly
  # (Python would try osascript from inside Automator's sandbox and fail).
  # Instead: create a temp .command file with the paths baked in, then open it
  # in Terminal.app — bash never blocks, Automator sees exit 0 immediately.
  local shell_cmd
  shell_cmd=$(cat <<SHELL
_base=\$(mktemp /tmp/cyber_XXXXXX)
_ct="\${_base}.command"
mv "\$_base" "\$_ct"
chmod +x "\$_ct"
{
  echo '#!/bin/bash'
  if [[ \$# -gt 0 ]]; then
    for _f in "\$@"; do
      printf '${CYBERTRANS} ${flags} %q\\n' "\$_f"
    done
  else
    while IFS= read -r _f; do
      printf '${CYBERTRANS} ${flags} %q\\n' "\$_f"
    done
  fi
  echo 'echo'
  echo 'read -rn1 -p "  done — press any key to close"'
  echo 'rm -f "\$0"'
} > "\$_ct"
open -a Terminal "\$_ct"
SHELL
)

  # Automator document.wflow  ─────────────────────────────────────────────────
  cat > "$contents/document.wflow" <<WFLOW
