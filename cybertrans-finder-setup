}

install() {
  mkdir -p "$SERVICES_DIR"
  local i installed=0
  for (( i=0; i<${#NAMES[@]}; i++ )); do
    make_workflow "${NAMES[$i]}" "${FLAGS[$i]}"
    echo "  ${GREEN}✓${RESET} ${BOLD}${NAMES[$i]}${RESET}"
    ((installed++)) || true
  done

  # Reload Services registry
  /System/Library/CoreServices/pbs -update 2>/dev/null || true

  echo ""
  echo "  ${PINK}${BOLD}✦ ${installed} Quick Actions installed to ~/Library/Services/${RESET}"
  echo ""
  echo "  ${BLUE}Enable them in:${RESET}"
  echo "  ${BOLD}System Settings → Privacy & Security → Extensions → Finder${RESET}"
  echo "  (tick each 'CyberTrans' entry)"
  echo ""
  echo "  ${GREY}To remove:  cybertrans-finder-setup --uninstall${RESET}"
}

case "${1:-}" in
  --uninstall|-u) uninstall ;;
  --help|-h)
    echo "Usage: cybertrans-finder-setup [--uninstall]"
    echo "  (no args)    install 4 Finder Quick Actions"
    echo "  --uninstall  remove them"
    ;;
  "") install ;;
  *) echo "${RED}unknown option: $1${RESET}"; exit 1 ;;
esac
